SOUNDCLOUD_CLIENT_ID=your_client_id
SOUNDCLOUD_CLIENT_SECRET=your_client_secret
SOUNDCLOUD_REDIRECT_URI=http://localhost:3000/auth/callback

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=soundcloud
DATABASE_PASSWORD=soundcloud
DATABASE_NAME=soundcloud_desktop

PORT=3000

# ─── Cloudflare Proxy (опционально) ───
# Если задан SC_PROXY_URL — все запросы к SC API идут через CF Worker с X-Target header
SC_PROXY_URL=
# Альтернативно — прямая замена base URL (без X-Target)
SC_API_PROXY_URL=
SC_AUTH_PROXY_URL=

# ─── CDN (опционально) ───
# SecureServe CDN для кэширования аудио
CDN_BASE_URL=
CDN_AUTH_TOKEN=

# ─── Telegram алерты (опционально) ───
# Уведомления при бане OAuth-аппки
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Admin API (опционально) ───
# Токен для управления OAuth-аппками через /oauth-apps
ADMIN_TOKEN=
